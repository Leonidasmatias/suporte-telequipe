# String de conexão do PostgreSQL usada pelo Prisma.
#
# Desenvolvimento local (Postgres rodando na sua máquina ou em Docker):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/suporte_telequipe?schema=public"
#
# Railway: no seu projeto, adicione o plugin "PostgreSQL" e copie a variável
# DATABASE_URL gerada automaticamente em Postgres → Variables → DATABASE_URL.
#
# Vercel: cole o mesmo valor em Project Settings → Environment Variables.
# Se estiver usando um pooler de conexões (ex: PgBouncer/Prisma Accelerate),
# configure também DIRECT_URL apontando para a conexão direta (não pooled) e
# adicione `directUrl = env("DIRECT_URL")` no datasource do schema.prisma —
# necessário para rodar migrations através do pooler.
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"

# Controle de acesso (Etapa 1 — Autenticação): a partir da Etapa 3, o
# sistema exige login por usuário (e-mail + senha) para qualquer acesso —
# não existe mais visualização livre nem senha compartilhada de "modo de
# edição". A antiga variável EDIT_PASSWORD foi REMOVIDA/obsoleta.
#
# Segredo usado para assinar o cookie de sessão do usuário logado (HMAC).
# Gere um valor aleatório, por exemplo com: openssl rand -hex 32
AUTH_SECRET="gere-uma-string-aleatoria-longa-aqui"

# Credenciais da conta ADMIN inicial, criada automaticamente por
# `npm run seed` (prisma/seed.ts) caso ainda não exista nenhum usuário com
# este e-mail. Defina antes de rodar o seed em produção; troque a senha
# pelo próprio sistema (Usuários) após o primeiro login.
ADMIN_SEED_EMAIL="admin@suaempresa.com"
ADMIN_SEED_NOME="Administrador"
ADMIN_SEED_SENHA="defina-uma-senha-forte-aqui"
