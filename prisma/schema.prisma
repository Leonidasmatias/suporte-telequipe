// SUPORTE TELEQUIPE — schema Prisma (PostgreSQL)
//
// Modelagem alinhada à especificação da V3 (Leader, Equipe, Colaborador,
// CompetenciaNokia, AvaliacaoCompetencia, Treinamento). O modelo
// TreinamentoColaborador foi mantido como tabela de junção (não estava na
// lista literal do briefing) porque a regra de negócio existente depende
// dele: a página /treinamentos exibe "participantes" por treinamento e
// /insights-operacionais cria treinamentos já vinculados a um colaborador.
//
// IDs: mantidos como Int autoincrement (em vez de String/cuid) para preservar
// 100% da lógica de Server Actions existente, que já trabalha com
// Number(formData.get("id")) em toda a aplicação.
//
// V4: adicionou a CENTRAL DE SUPORTE TÉCNICO (model SupportTicket).
//
// V5: adicionou Equipe.codigo (código sequencial TQ-000X).
//
// V6 — REESTRUTURAÇÃO CORPORATIVA: os models Leader e Equipe foram removidos
// por completo. O sistema passa a ter uma única entidade central de pessoas:
// Colaborador (Cadastro Mestre), alimentada por sincronização em massa
// (Smart Sync) a partir de um único arquivo Excel oficial. Não há mais
// distinção entre líder/instalador nem agrupamento por equipe.
//
// V6.1 — AJUSTE PÓS-ANÁLISE DA PLANILHA REAL: a coluna "Cadastro" do arquivo
// oficial não é uma matrícula/ID único — na prática ela lista as operadoras/
// clientes que o colaborador atende (ex.: "ERICSSON/NOKIA"), repete entre
// colaboradores diferentes e frequentemente vem vazia. Por isso ela NÃO pode
// ser chave de deduplicação e foi renomeada para `operadoras` (texto livre,
// sem unicidade). A chave natural de identificação do Smart Sync passou a
// ser `nomeNormalizado` (nome em maiúsculas, sem acento, espaços colapsados),
// única e derivada automaticamente de `nome` a cada import/edição.
//
// SupportTicket passa a pertencer a um único colaborador (colaboradorId).
// Os campos liderNomeHistorico/equipeNomeHistorico preservam, como texto
// solto (sem FK), o nome do líder/equipe que constavam nos atendimentos
// registrados antes desta reestruturação — decisão explícita do usuário foi
// começar o Cadastro Mestre do zero (sem migrar líderes/equipes antigos para
// Colaborador), então esses atendimentos legados não podem apontar para um
// colaboradorId válido, mas o texto fica preservado para consulta histórica.
//
// V7 — ETAPA 1/2/3 (AUTENTICAÇÃO, GESTÃO DE USUÁRIOS, PERMISSÕES): adicionado
// o model Usuario (conta individual, com e-mail/senha e perfil ADMIN ou
// TECNICO) e o enum PerfilUsuario. Substitui o antigo modelo de "modo de
// edição" por senha única compartilhada (cookie `edicao_sessao`, ver commit
// "Controle de acesso: modo de edicao com senha, visualizacao livre") por
// autenticação real por usuário — ver lib/auth.ts e lib/autorizacao.ts.
// Único usuário próprio do sistema (não confundir com Colaborador, que é o
// Cadastro Mestre de pessoal de campo — um Usuario pode ou não corresponder
// a um Colaborador; são entidades independentes por decisão explícita, para
// não acoplar login/permissão a dados operacionais de RH).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PerfilUsuario {
  ADMIN
  TECNICO
}

/// Conta de acesso ao sistema (login). Independente do Cadastro Mestre de
/// Colaboradores — ver nota V7 no topo do arquivo.
model Usuario {
  id     Int    @id @default(autoincrement())
  nome   String
  email  String @unique

  /// Hash scrypt (salt + hash em hex, formato "salt:hash") — nunca a senha em texto puro. Ver lib/senha.ts.
  senhaHash String

  perfil PerfilUsuario

  /// Usuário inativado perde acesso imediatamente (toda verificação relê este campo do banco a cada requisição — ver lib/auth.ts).
  ativo Boolean @default(true)

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@map("usuarios")
}

model Colaborador {
  id     Int    @id @default(autoincrement())
  nome   String

  // Cópia normalizada de `nome` (maiúsculas, sem acento, espaços
  // colapsados) — chave natural estável usada pelo Smart Sync para
  // reconhecer "é o mesmo colaborador" entre importações, já que a
  // planilha oficial não traz nenhum ID/matrícula confiável (ver nota V6.1
  // no topo do arquivo). Calculada automaticamente a partir de `nome`,
  // nunca preenchida manualmente. Nullable+unique por segurança do Prisma,
  // mas sempre preenchida na prática (todo colaborador tem nome).
  nomeNormalizado String? @unique

  // "CLT", "PJ - EXTERNO", "PJ - INTERNO" ou outro classificador de vínculo
  // — texto livre, vindo do Excel (não restringimos a um enum fixo porque
  // novas categorias podem aparecer em importações futuras).
  tipoPessoa String?
  regional   String?

  // Operadoras/clientes que o colaborador atende (ex.: "ERICSSON/NOKIA").
  // Texto livre vindo da coluna "Cadastro" da planilha oficial — apesar do
  // nome da coluna de origem, NÃO é um identificador único (ver nota V6.1).
  operadoras String?

  empresaNome String?
  cargo       String?
  telefone    String?

  // "ativo" | "inativo". Smart Sync marca como "inativo" (nunca exclui)
  // qualquer colaborador que não apareça mais no Excel importado.
  status String @default("ativo")

  // Quando este colaborador foi visto pela última vez em uma importação, e
  // quando seus dados foram alterados pela última vez (import ou edição manual).
  dataImportacao    DateTime?
  ultimaAtualizacao DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  avaliacoes     AvaliacaoCompetencia[]
  treinamentos   TreinamentoColaborador[]
  supportTickets SupportTicket[]

  @@map("colaboradores")
}

model CompetenciaNokia {
  id        Int      @id @default(autoincrement())
  // Código fixo da etapa Nokia: MOS, XML, TX, SWAP, FAM ou REVERSA.
  nome      String   @unique
  createdAt DateTime @default(now())

  avaliacoes AvaliacaoCompetencia[]

  @@map("competencias_nokia")
}

model AvaliacaoCompetencia {
  id            Int       @id @default(autoincrement())
  colaboradorId Int
  competenciaId Int
  // Nota de 0 a 100 — equivalente ao "imt_score" da V2.
  nota          Int
  nivel         String    @default("Não certificado")
  avaliadoEm    DateTime?
  createdAt     DateTime  @default(now())

  colaborador Colaborador      @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)
  competencia CompetenciaNokia @relation(fields: [competenciaId], references: [id], onDelete: Cascade)

  @@index([colaboradorId, competenciaId])
  @@map("avaliacoes_competencia")
}

model Treinamento {
  id           Int       @id @default(autoincrement())
  titulo       String
  descricao    String?
  categoria    String?
  cargaHoraria Int?
  data         DateTime?
  instrutor    String?
  createdAt    DateTime  @default(now())

  colaboradores TreinamentoColaborador[]

  @@map("treinamentos")
}

model TreinamentoColaborador {
  id            Int    @id @default(autoincrement())
  treinamentoId Int
  colaboradorId Int
  status        String @default("pendente")

  treinamento Treinamento @relation(fields: [treinamentoId], references: [id], onDelete: Cascade)
  colaborador Colaborador @relation(fields: [colaboradorId], references: [id], onDelete: Cascade)

  @@map("treinamento_colaboradores")
}

// ============================================================
// CENTRAL DE SUPORTE TÉCNICO
// ============================================================
// Banco de conhecimento operacional: registra todo atendimento técnico
// prestado a colaboradores de campo (telefone, WhatsApp, remoto,
// presencial...). Alimenta KPIs, indicadores automáticos e, futuramente, a
// camada de IA operacional. V6: cada atendimento pertence a um único
// colaborador (não existe mais atendimento por equipe/líder).
model SupportTicket {
  id     Int @id @default(autoincrement())
  // Numeração sequencial amigável para exibição ("Atendimento #numero"),
  // independente do id interno.
  numero Int @unique @default(autoincrement())

  dataAtendimento DateTime
  horaInicio      String
  horaFim         String?
  // Calculado automaticamente a partir de horaInicio/horaFim, em minutos.
  tempoAtendimento Int?

  colaboradorId Int?

  // Snapshot em texto (sem FK) do líder/equipe que constavam em atendimentos
  // registrados antes da reestruturação V6 — ver comentário no topo do
  // arquivo. Somente leitura/histórico; novos atendimentos não preenchem
  // estes campos.
  liderNomeHistorico  String?
  equipeNomeHistorico String?

  projeto String?
  cliente String?
  // Site atendido (ex.: "SN-AQDIK4"). Opcional — preserva atendimentos
  // antigos (registrados antes deste campo existir) e permite atendimentos
  // administrativos sem site associado. Normalizado em maiúsculas na
  // camada de Server Action (app/suporte/actions.ts, normalizarSite em
  // lib/suporte.ts) antes de chegar aqui — nunca validado de novo no schema.
  site String?

  tipoAtendimento String
  categoria       String

  descricaoProblema  String
  solucaoAplicada    String?
  resultado          String
  status             String  @default("Aberto")
  observacoes        String?
  tecnicoResponsavel String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  colaborador Colaborador? @relation(fields: [colaboradorId], references: [id], onDelete: SetNull)

  @@index([colaboradorId])
  @@index([status])
  @@index([categoria])
  @@map("support_tickets")
}
